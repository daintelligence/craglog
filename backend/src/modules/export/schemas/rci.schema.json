{
  "format": "rci",
  "version": "1.0",
  "description": "RCI-style UK climbing certification export",
  "fields": [
    { "target": "Date",         "source": "date",                 "required": true },
    { "target": "Area",         "source": "crag.region.name",     "required": true,  "fallback": "crag.name" },
    { "target": "Crag",         "source": "crag.name",            "required": true },
    { "target": "Route",        "source": "route.name",           "required": true },
    { "target": "Grade",        "source": "route.grade",          "required": true },
    { "target": "Method",       "source": "ascentType",           "required": true,  "transform": "rci_method" },
    { "target": "Type",         "source": "route.climbingType",   "required": true,  "transform": "capitalize" },
    { "target": "Pitches",      "source": "route.pitches",        "required": false, "default": "1" },
    { "target": "RockType",     "source": "crag.rockType",        "required": false, "transform": "capitalize" },
    { "target": "Partner",      "source": "partner",              "required": false },
    { "target": "Notes",        "source": "notes",                "required": false }
  ],
  "transforms": {
    "rci_method": {
      "onsight": "Lead - Onsight",
      "flash": "Lead - Flash",
      "redpoint": "Lead - Redpoint",
      "second": "Second",
      "dog": "Lead - Worked",
      "solo": "Solo",
      "abseil": "Abseil"
    },
    "capitalize": "auto"
  },
  "validation": {
    "requiredFields": ["Date", "Area", "Crag", "Route", "Grade", "Method"],
    "dateFormat": "DD/MM/YYYY"
  }
}
